<?xml version="1.0" encoding="UTF-8"?>
<!-- scan 已移除：scan + springProfile 组合在 logback 重扫描时会丢失 Spring 扩展注册，导致重载后 springProfile 内配置失效 -->
<configuration>

    <!--
        从 Spring Environment 读取日志路径配置
        来源：application-dev.yml → logging.file.path
        默认：../docs/开发文档/log/backend（相对 backend/ 目录）
    -->
    <springProperty scope="context" name="LOG_PATH"
                    source="logging.file.path"
                    defaultValue="../docs/开发文档/log/backend"/>

    <!-- ================================================================
         Console Appender
         ================================================================ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <!-- 带颜色的控制台格式 -->
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan([%thread]) %yellow(%logger{36}) - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ================================================================
         File Appender - 全量日志（按天滚动）
         输出文件：backend.log（当日） / backend-yyyy-MM-dd.log（历史）
         ================================================================ -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/backend.log</file>
        <!-- 立即刷盘，不走缓冲 -->
        <immediateFlush>true</immediateFlush>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/backend-%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 保留最近 30 天 -->
            <maxHistory>30</maxHistory>
            <!-- 总容量上限 500MB -->
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ================================================================
         File Appender - 仅 ERROR 级别
         输出文件：error.log（当日） / error-yyyy-MM-dd.log（历史）
         ================================================================ -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <file>${LOG_PATH}/error.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/error-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ================================================================
         Dev Profile：控制台 + 文件双输出
         ================================================================ -->
    <springProfile name="dev">

        <!-- 业务代码：DEBUG 级别，不上报到 root（避免重复输出） -->
        <logger name="com.huiwutong.conference" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>

        <!-- MyBatis SQL 日志：DEBUG，独立控制 -->
        <logger name="com.huiwutong.conference.mapper" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>

        <!-- 其他框架日志：INFO -->
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>

    </springProfile>

    <!-- ================================================================
         Prod Profile：只写文件，不输出控制台
         ================================================================ -->
    <springProfile name="prod">

        <logger name="com.huiwutong.conference" level="INFO" additivity="false">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>

        <root level="WARN">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>

    </springProfile>

</configuration>
